function Library:GetIcon(iconName)
	if type(iconName) ~= "string" then
		return ""
	end
	-- Nếu là rbxassetid thì trả về trực tiếp
	if iconName:find("rbxassetid://") then
		return iconName
	end
	-- Tìm trong bảng Icons
	local lowerName = string.lower(iconName)
	if IconsList[lowerName] then
		return IconsList[lowerName]
	end
	-- Tìm gần đúng
	for name, id in pairs(IconsList) do
		if name:find(lowerName, 1, true) then
			return id
		end
	end
	return iconName
end

local function isValidIcon(icon)
	if type(icon) ~= "string" then
		return false
	end
	return icon:find("rbxassetid://") and icon:gsub("rbxassetid://", ""):len() >= 6
end

