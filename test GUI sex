	function Tab:AddDropdown(configs)
		local name = configs[1] or configs.Name or configs.Title or "Dropdown"
		local items = configs.Items or configs[2] or {}
		local defaultValue = configs.Default or items[1]
		local callback = configs.Callback or function() end

		local selectedValue = defaultValue

		local DropdownButton = Instance.new("TextButton")
		DropdownButton.Parent = Page
		DropdownButton.Size = UDim2.new(1, 0, 0, 42)
		DropdownButton.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
		DropdownButton.BorderSizePixel = 0
		DropdownButton.AutoButtonColor = false
		DropdownButton.Text = ""

		local Corner = Instance.new("UICorner")
		Corner.Parent = DropdownButton
		Corner.CornerRadius = UDim.new(0, 10)

		local Stroke = Instance.new("UIStroke")
		Stroke.Parent = DropdownButton
		Stroke.Color = Color3.fromRGB(18, 18, 18)

		local TitleLabel = Instance.new("TextLabel")
		TitleLabel.Parent = DropdownButton
		TitleLabel.BackgroundTransparency = 1
		TitleLabel.Position = UDim2.new(0, 12, 0, 0)
		TitleLabel.Size = UDim2.new(0.5, -12, 1, 0)
		TitleLabel.Font = Enum.Font.GothamBold
		TitleLabel.Text = name
		TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		TitleLabel.TextSize = 12
		TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

		local ValueLabel = Instance.new("TextLabel")
		ValueLabel.Parent = DropdownButton
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.Position = UDim2.new(0.5, 0, 0, 0)
		ValueLabel.Size = UDim2.new(0.5, -24, 1, 0)
		ValueLabel.Font = Enum.Font.Gotham
		ValueLabel.Text = tostring(selectedValue)
		ValueLabel.TextColor3 = Color3.fromRGB(100, 200, 100)
		ValueLabel.TextSize = 11
		ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

		local DropdownIcon = Instance.new("ImageLabel")
		DropdownIcon.Parent = DropdownButton
		DropdownIcon.Size = UDim2.new(0, 14, 0, 14)
		DropdownIcon.Position = UDim2.new(1, -22, 0.5, -7)
		DropdownIcon.BackgroundTransparency = 1
		DropdownIcon.Image = "rbxassetid://10709790948"

		local isOpen = false

		local function toggleDropdown()
			isOpen = not isOpen
			if isOpen then
				local dropdownList = Instance.new("Frame")
				dropdownList.Parent = Page
				dropdownList.Name = "DropdownList"
				dropdownList.Size = UDim2.new(1, 0, 0, #items * 28 + 4)
				dropdownList.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
				dropdownList.BorderSizePixel = 0

				local ListCorner = Instance.new("UICorner")
				ListCorner.Parent = dropdownList
				ListCorner.CornerRadius = UDim.new(0, 8)

				local ListLayout = Instance.new("UIListLayout")
				ListLayout.Parent = dropdownList
				ListLayout.Padding = UDim.new(0, 2)

				local ListPadding = Instance.new("UIPadding")
				ListPadding.Parent = dropdownList
				ListPadding.PaddingTop = UDim.new(0, 2)
				ListPadding.PaddingLeft = UDim.new(0, 2)
				ListPadding.PaddingRight = UDim.new(0, 2)
				ListPadding.PaddingBottom = UDim.new(0, 2)

				for _, item in ipairs(items) do
					local ItemButton = Instance.new("TextButton")
					ItemButton.Parent = dropdownList
					ItemButton.Size = UDim2.new(1, 0, 0, 24)
					ItemButton.BackgroundColor3 = item == selectedValue and Color3.fromRGB(15, 15, 15) or Color3.fromRGB(5, 5, 5)
					ItemButton.BorderSizePixel = 0
					ItemButton.Text = tostring(item)
					ItemButton.TextColor3 = Color3.fromRGB(255, 255, 255)
					ItemButton.Font = Enum.Font.Gotham
					ItemButton.TextSize = 12

					local ItemCorner = Instance.new("UICorner")
					ItemCorner.Parent = ItemButton
					ItemCorner.CornerRadius = UDim.new(0, 6)

					ItemButton.Activated:Connect(function()
						selectedValue = item
						ValueLabel.Text = tostring(selectedValue)
						if type(callback) == "function" then
							callback(selectedValue)
						end
						isOpen = false
						dropdownList:Destroy()
					end)
				end
			else
				local existingList = Page:FindFirstChild("DropdownList")
				if existingList then
					existingList:Destroy()
				end
			end
		end

		DropdownButton.Activated:Connect(toggleDropdown)

		local DropdownInstance = {}
		function DropdownInstance:Get()
			return selectedValue
		end
		function DropdownInstance:Set(value)
			if table.find(items, value) then
				selectedValue = value
				ValueLabel.Text = tostring(selectedValue)
			end
		end
		function DropdownInstance:Visible(state)
			if state == nil then
				DropdownButton.Visible = not DropdownButton.Visible
			else
				DropdownButton.Visible = state
			end
		end
		function DropdownInstance:Destroy()
			DropdownButton:Destroy()
		end

		return DropdownInstance
	end

