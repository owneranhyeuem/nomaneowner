	function Tab:AddSlider(configs)
		local name = configs[1] or configs.Name or configs.Title or "Slider"
		local min = configs.Min or configs.Minimum or 0
		local max = configs.Max or configs.Maximum or 100
		local defaultValue = configs.Default or configs[2] or min
		local callback = configs.Callback or function() end

		local sliderValue = math.clamp(defaultValue, min, max)

		local Slider = Instance.new("TextButton")
		Slider.Parent = Page
		Slider.Size = UDim2.new(1, 0, 0, 56)
		Slider.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
		Slider.BorderSizePixel = 0
		Slider.AutoButtonColor = false
		Slider.Text = ""

		local Corner = Instance.new("UICorner")
		Corner.Parent = Slider
		Corner.CornerRadius = UDim.new(0, 10)

		local Stroke = Instance.new("UIStroke")
		Stroke.Parent = Slider
		Stroke.Color = Color3.fromRGB(18, 18, 18)

		local TitleLabel = Instance.new("TextLabel")
		TitleLabel.Parent = Slider
		TitleLabel.BackgroundTransparency = 1
		TitleLabel.Position = UDim2.new(0, 12, 0, 8)
		TitleLabel.Size = UDim2.new(0.7, -24, 0, 16)
		TitleLabel.Font = Enum.Font.GothamBold
		TitleLabel.Text = name
		TitleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
		TitleLabel.TextSize = 14
		TitleLabel.TextXAlignment = Enum.TextXAlignment.Left

		local ValueLabel = Instance.new("TextLabel")
		ValueLabel.Parent = Slider
		ValueLabel.BackgroundTransparency = 1
		ValueLabel.Position = UDim2.new(0.7, 0, 0, 8)
		ValueLabel.Size = UDim2.new(0.3, -12, 0, 16)
		ValueLabel.Font = Enum.Font.Gotham
		ValueLabel.Text = tostring(math.floor(sliderValue))
		ValueLabel.TextColor3 = Color3.fromRGB(100, 200, 100)
		ValueLabel.TextSize = 12
		ValueLabel.TextXAlignment = Enum.TextXAlignment.Right

		local SliderBar = Instance.new("Frame")
		SliderBar.Parent = Slider
		SliderBar.Size = UDim2.new(1, -24, 0, 6)
		SliderBar.Position = UDim2.new(0, 12, 0, 30)
		SliderBar.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
		SliderBar.BorderSizePixel = 0

		local BarCorner = Instance.new("UICorner")
		BarCorner.Parent = SliderBar
		BarCorner.CornerRadius = UDim.new(0, 3)

		local Progress = Instance.new("Frame")
		Progress.Parent = SliderBar
		Progress.Size = UDim2.new((sliderValue - min) / (max - min), 0, 1, 0)
		Progress.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
		Progress.BorderSizePixel = 0

		local ProgressCorner = Instance.new("UICorner")
		ProgressCorner.Parent = Progress
		ProgressCorner.CornerRadius = UDim.new(0, 3)

		local SliderBall = Instance.new("Frame")
		SliderBall.Parent = SliderBar
		SliderBall.Size = UDim2.new(0, 14, 0, 14)
		SliderBall.Position = UDim2.new((sliderValue - min) / (max - min), -7, 0.5, -7)
		SliderBall.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
		SliderBall.BorderSizePixel = 0

		local BallCorner = Instance.new("UICorner")
		BallCorner.Parent = SliderBall
		BallCorner.CornerRadius = UDim.new(0, 7)

		local function updateSlider(position)
			local barSize = SliderBar.AbsoluteSize.X
			local barPos = position - SliderBar.AbsolutePosition.X
			local percentage = math.clamp(barPos / barSize, 0, 1)
			sliderValue = math.floor(min + (max - min) * percentage + 0.5)
			ValueLabel.Text = tostring(sliderValue)
			Progress.Size = UDim2.new(percentage, 0, 1, 0)
			SliderBall.Position = UDim2.new(percentage, -7, 0.5, -7)
			if type(callback) == "function" then
				callback(sliderValue)
			end
		end

		local isDragging = false
		SliderBall.InputBegan:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				isDragging = true
			end
		end)

		UIS.InputChanged:Connect(function(input)
			if isDragging and input.UserInputType == Enum.UserInputType.MouseMovement then
				updateSlider(input.Position.X)
			end
		end)

		UIS.InputEnded:Connect(function(input)
			if input.UserInputType == Enum.UserInputType.MouseButton1 then
				isDragging = false
			end
		end)

		local SliderInstance = {}
		function SliderInstance:Get()
			return sliderValue
		end
		function SliderInstance:Set(value)
			sliderValue = math.clamp(value, min, max)
			ValueLabel.Text = tostring(sliderValue)
			local percentage = (sliderValue - min) / (max - min)
			Progress.Size = UDim2.new(percentage, 0, 1, 0)
			SliderBall.Position = UDim2.new(percentage, -7, 0.5, -7)
		end
		function SliderInstance:Visible(state)
			if state == nil then
				Slider.Visible = not Slider.Visible
			else
				Slider.Visible = state
			end
		end
		function SliderInstance:Destroy()
			Slider:Destroy()
		end

		return SliderInstance
	end

