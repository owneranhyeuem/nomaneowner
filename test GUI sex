			}):Play()
			TweenService:Create(ToggleBox, TweenInfo.new(0.2), {
				BackgroundColor3 = value and Color3.fromRGB(100, 200, 100) or Color3.fromRGB(50, 50, 50)
			}):Play()
			if type(callback) == "function" then
				callback(value)
			end
		end

		Toggle.Activated:Connect(function()
			updateToggle(not ToggleValue)
		end)

		local ToggleInstance = {}
