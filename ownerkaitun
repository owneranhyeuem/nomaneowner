local function b64decode(data)

    if syn and syn.crypt and syn.crypt.base64 then
        return syn.crypt.base64.decode(data)
    end

    if crypt and crypt.base64decode then
        return crypt.base64decode(data)
    end

    if base64 and base64.decode then
        return base64.decode(data)
    end

    error("executor no base64")
end


local function xorDecrypt(
    data,
    key
)

    local result = {}

    for i = 1, #data do

        local a =
            string.byte(data, i)

        local b =
            string.byte(
                key,
                ((i - 1) % #key) + 1
            )

        result[i] =
            string.char(
                bit.bxor(a, b)
            )
    end

    return table.concat(result)
end


local function decrypt(
    payload,
    key,
    left,
    right
)


    payload =
        payload:sub(
            left + 1,
            #payload - right
        )


    payload =
        payload
            :reverse()


    payload =
        b64decode(payload)


    payload =
        xorDecrypt(
            payload,
            key
        )

    return payload
end

