local Time = V1:AddLabel("Loading Time Zone...")

function UpdateOS()
    local date = os.date("*t")
    local hour = (date.hour) % 24
    local ampm = hour < 12 and "AM" or "PM"

    local timezone = string.format(
        "%02i:%02i:%02i %s",
        ((hour - 1) % 12) + 1,
        date.min,
        date.sec,
        ampm
    )

    local datetime = string.format(
        "%02d/%02d/%04d",
        date.day,
        date.month,
        date.year
    )

    local LocalizationService = game:GetService("LocalizationService")
    local Players = game:GetService("Players")
    local player = Players.LocalPlayer

    local code = "??"

    pcall(function()
        code = LocalizationService:GetCountryRegionForPlayerAsync(player)
    end)

    Time:SetText(datetime .. " - " .. timezone .. " [ " .. code .. " ]")
end

spawn(function()
    while wait(1) do
        UpdateOS()
    end
end)

