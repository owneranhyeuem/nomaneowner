local plr = game.Players.LocalPlayer
local Vim = game:GetService("VirtualInputManager")

task.spawn(function()
    while task.wait() do
        pcall(function()
            if getgenv().V4
            and plr.Character
            and plr.Character:FindFirstChild("RaceTransformed") then

                if not plr.Character.RaceTransformed.Value then
                    Vim:SendKeyEvent(true,"Y",false,game)
                    task.wait(.1)
                    Vim:SendKeyEvent(false,"Y",false,game)
                end
            end
        end)
    end
end)

local function Press(key)
    Vim:SendKeyEvent(true, key, false, game)
    task.wait(0.1)
    Vim:SendKeyEvent(false, key, false, game)
end

local function UseSkill(key, toggle, cooldown)
    task.spawn(function()
        while task.wait(0.2) do
            pcall(function()

                if not getgenv().config.useSkill then
                    return
                end

                if getgenv()[toggle] then
                    Press(key)
                    task.wait(cooldown)
                end

            end)
        end
    end)
end

UseSkill("Z", "SkillZ", 1)
UseSkill("X", "SkillX", 2)
UseSkill("C", "SkillC", 3)
UseSkill("V", "SkillV", 4)
UseSkill("F", "SkillF", 5)
